## Uncomment to allow members of group wheel to execute any command
%wheel ALL=(ALL:ALL) ALL

## Same thing without a password
%wheel ALL=(ALL:ALL) NOPASSWD: /usr/bin/pacman -Syu, /usr/bin/loginctl hibernate, /usr/bin/loginctl poweroff, /usr/bin/loginctl reboot, /usr/bin/loginctl reboot --firmware-setup, /usr/bin/loginctl suspend
